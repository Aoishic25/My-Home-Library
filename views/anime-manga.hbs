<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anime & Manga</title>
    <link rel="stylesheet" href="/style6.css">
</head>
<body>
    <header>
        <a href="/" class="back-btn">Back</a>
        <h1>Anime &amp; Manga</h1>
    </header>

    <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('anime',this)">Anime</button>
        <button class="tab-btn" onclick="switchTab('manga',this)">Manga</button>
    </div>

    <div id="tab-anime" class="tab-content active">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Name</th>
                        <th>Japanese Title</th>
                        <th>Seasons</th>
                        <th>Type</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each anime}}
                    <tr>
                        <td class="row-no">{{this.No}}</td>
                        <td>{{this.Name}}</td>
                        <td>{{this.Japanese}}</td>
                        <td>
                            {{#if this.seasons}}
                                {{this.seasons}}
                            {{else}}
                                <span class="null-val">—</span>
                            {{/if}}
                        </td>
                        <td>
                            {{#matchAnimeType "Anime" "Type"}}
                                {{#if (eq this.Type "Series")}}
                                    <span class="badge badge-series">Series</span>
                                {{else}}
                                    <span class="badge badge-movie">Movie</span>
                                {{/if}}
                            {{/matchAnimeType}}
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <div id="tab-manga" class="tab-content">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Name</th>
                        <th>Japanese Title</th>
                        <th>Hepburn</th>
                        <th>Writer</th>
                        <th>Volumes</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each manga}}
                    <tr>
                        <td class="row-no">{{this.No}}</td>
                        <td>{{this.Name}}</td>
                        <td>{{this.Japanese}}</td>
                        <td>{{this.Hepburn}}</td>
                        <td>{{this.Writer}}</td>
                        <td>{{this.Volumes}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        function switchTab(name,btn){
            document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
            document.getElementById('tab-'+name).classList.add('active');
            btn.classList.add('active');
        }
    </script>
</body>
</html>